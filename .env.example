# ────────────────────────────────────────────────────────────────────────────
# OpenFund — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (local or cloud)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/openfund?schema=public"

# ── NextAuth.js ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
# Public URL of your deployment (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Homepage URL:              http://localhost:3000
# Authorization callback:   http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ── Stellar / Horizon ─────────────────────────────────────────────────────────
# "testnet" or "mainnet"
STELLAR_NETWORK="testnet"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# ── Soroban RPC ───────────────────────────────────────────────────────────────
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"

# ── Milestone Escrow Contract ─────────────────────────────────────────────────
# Deployed contract address on testnet
ESCROW_CONTRACT_ID="CCRZRCMEVQUV6WM2IJVWTIDDLHFJAWRVWR4JR3YBWY6JA5E3RREP7QQS"
# Secret key of the deployer account (needed for read-only simulations)
ESCROW_DEPLOYER_SECRET="your-stellar-secret-key"

# ── USDC Stellar Asset Contract ───────────────────────────────────────────────
# Testnet USDC SAC address (Circle USDC on testnet)
USDC_SAC_ADDRESS="CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA"

# ── Public variables (exposed to the browser) ─────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STELLAR_NETWORK="testnet"
NEXT_PUBLIC_ESCROW_CONTRACT_ID="CCRZRCMEVQUV6WM2IJVWTIDDLHFJAWRVWR4JR3YBWY6JA5E3RREP7QQS"
